# ─── MODE ────────────────────────────────────────────────────────────────────
# "fake" = Mumbai testnet (no real money)
# "real" = Polygon mainnet (real wallet)
TRADING_MODE=fake

# Set to true to log orders without submitting (extra safety layer)
DRY_RUN=true

# ─── NETWORK ─────────────────────────────────────────────────────────────────
# fake: https://rpc-mumbai.maticvigil.com  (or Alchemy/Infura Mumbai endpoint)
# real: https://polygon-rpc.com
RPC_URL=https://rpc-mumbai.maticvigil.com

# fake: 80001 (Mumbai)  |  real: 137 (Polygon)
CHAIN_ID=80001

# fake: https://clob.polymarket.com (testnet)  |  real: https://clob.polymarket.com
POLYMARKET_HOST=https://clob.polymarket.com

# ─── WALLET ──────────────────────────────────────────────────────────────────
WALLET_ADDRESS=0xYourWalletAddressHere
WALLET_PRIVATE_KEY=your_private_key_here_without_0x_prefix

# ─── POLYMARKET CLOB API KEYS ─────────────────────────────────────────────────
# Generate via Polymarket dashboard → API Keys
API_KEY=your_clob_api_key
API_SECRET=your_clob_api_secret
API_PASSPHRASE=your_clob_api_passphrase

# ─── CLAUDE AI ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here
CLAUDE_MODEL=claude-opus-4-6

# How often to run the analysis loop (minutes)
ANALYZE_INTERVAL_MINUTES=15

# ─── RISK MANAGEMENT ─────────────────────────────────────────────────────────
# Maximum single order size in USDC
MAX_ORDER_SIZE_USDC=10.0

# Maximum total open exposure across all positions in USDC
MAX_TOTAL_EXPOSURE_USDC=100.0

# Maximum number of concurrent open positions
MAX_POSITIONS=5

# Claude must return confidence >= this to place an order (0.0–1.0)
MIN_CONFIDENCE_SCORE=0.7

# ─── TELEGRAM ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Send notification on every order placed
NOTIFY_ON_ORDER=true

# Send P&L summary notifications
NOTIFY_ON_PNL=true

# How often to send P&L report (hours)
PNL_REPORT_INTERVAL_HOURS=6

# ─── STRATEGY ────────────────────────────────────────────────────────────────
# Options: copy_trader | news | hybrid
STRATEGY=hybrid

# Address to mirror trades from (used in copy_trader / hybrid mode)
COPY_TRADER_ADDRESS=0xTargetTraderAddressHere

# Address to mirror trades from (used in copy_trader / hybrid mode)
COPY_TRADER_ADDRESS=
TAVILY_API_KEY=

# Focus pada market sports, crypto, dan Iran saja
MARKET_FOCUS_TAGS=Sports,Crypto,Geopolitics
MARKET_FOCUS_KEYWORDS=iran,bitcoin,btc,ethereum,eth,nba,nfl,premier league,champions league,world cup,strait of hormuz,nuclear,iaea,sanctions
FOOTBALL_DATA_API_KEY=